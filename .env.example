# Anjor Environment Variables
# Copy this to .env and fill in values

# Mode: "patch" (in-process httpx monkey-patch) or "proxy" (mitmproxy sidecar)
ANJOR_MODE=patch

# Ports
ANJOR_PROXY_PORT=7842
ANJOR_COLLECTOR_PORT=7843

# Storage — use ":memory:" for tests
ANJOR_DB_PATH=anjor.db

# Logging level: DEBUG, INFO, WARNING, ERROR
ANJOR_LOG_LEVEL=INFO

# Max payload size to accept (kilobytes)
ANJOR_MAX_PAYLOAD_SIZE_KB=512

# Batch writer settings
ANJOR_BATCH_SIZE=100
ANJOR_BATCH_INTERVAL_MS=500
