# AgentScope Environment Variables
# Copy this to .env and fill in values

# Mode: "patch" (in-process httpx monkey-patch) or "proxy" (mitmproxy sidecar)
AGENTSCOPE_MODE=patch

# Ports
AGENTSCOPE_PROXY_PORT=7842
AGENTSCOPE_COLLECTOR_PORT=7843

# Storage — use ":memory:" for tests
AGENTSCOPE_DB_PATH=agentscope.db

# Logging level: DEBUG, INFO, WARNING, ERROR
AGENTSCOPE_LOG_LEVEL=INFO

# Max payload size to accept (kilobytes)
AGENTSCOPE_MAX_PAYLOAD_SIZE_KB=512

# Batch writer settings
AGENTSCOPE_BATCH_SIZE=100
AGENTSCOPE_BATCH_INTERVAL_MS=500
