{
  "name": "@anjor-labs/sdk",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript SDK for the Anjor observability platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "node --test src/__tests__/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["observability", "llm", "agents", "monitoring", "anjor"],
  "author": "Anjor Labs",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
